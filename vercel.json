{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/AUREVON_NFT_Collection", "destination": "/aurevon-web3", "permanent": true },
    { "source": "/aurevon-nft",            "destination": "/aurevon-web3", "permanent": true },
    { "source": "/aurevon_nft_collection", "destination": "/aurevon-web3", "permanent": true },
    { "source": "/nft-collection",         "destination": "/aurevon-web3", "permanent": true },
    { "source": "/nft",                    "destination": "/aurevon-web3", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/stripe/checkout",       "destination": "/api/stripe/checkout.js" },
    { "source": "/api/webhooks/stripe",        "destination": "/api/webhooks/stripe.js" },
    { "source": "/api/webhooks/paypal",        "destination": "/api/webhooks/paypal.js" },
    { "source": "/api/webhooks/crossmint",     "destination": "/api/webhooks/crossmint.js" },
    { "source": "/api/portal/data",           "destination": "/api/portal/data.js" },
    { "source": "/api/portal/auth",           "destination": "/api/portal/auth.js" },
    { "source": "/api/portal/verify",         "destination": "/api/portal/verify.js" },
    { "source": "/api/health",                "destination": "/api/health.js" },
    { "source": "/api/discord/auth",          "destination": "/api/discord.js?action=auth" },
    { "source": "/api/discord/callback",      "destination": "/api/discord.js?action=callback" },
    { "source": "/api/discord/sync",          "destination": "/api/discord.js?action=sync" },
    { "source": "/api/discord/check-membership", "destination": "/api/discord.js?action=check-membership" },
    { "source": "/api/discord",               "destination": "/api/discord.js" },
    { "source": "/api/cron/retry-mints",      "destination": "/api/member/claim.js?action=retry-mints" },
    { "source": "/api/email/send",            "destination": "/api/email/send.js" },
    { "source": "/api/crossmint/mint",        "destination": "/api/crossmint/mint.js" },
    { "source": "/api/paypal/create-order",   "destination": "/api/paypal/create-order.js" },
    { "source": "/api/paypal/capture",        "destination": "/api/paypal/capture.js" },
    { "source": "/api/member/claim",          "destination": "/api/member/claim.js" },
    { "source": "/aurevon-re",               "destination": "/aurevon-re.html" },
    { "source": "/aurevon-web3",             "destination": "/aurevon-web3.html" },
    { "source": "/aurevon-crm",             "destination": "/aurevon-crm.html" },
    { "source": "/blockt-crm",              "destination": "/aurevon-crm.html" },
    { "source": "/portal",                  "destination": "/portal.html" },
    { "source": "/operator",                "destination": "/operator.html" },
    { "source": "/merch",                   "destination": "/merch.html" },
    { "source": "/discord-welcome",         "destination": "/discord-welcome.html" },
    { "source": "/membership-confirmation", "destination": "/membership_confirmation.html" },
    { "source": "/setup-wizard",            "destination": "/setup-wizard.html" },
    { "source": "/member-claim",            "destination": "/member-claim.html" },
    { "source": "/success",                 "destination": "/index.html" },
    { "source": "/cancel",                  "destination": "/index.html" },
    { "source": "/nfts",                    "destination": "/aurevon-web3.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://www.aurevonvc.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
