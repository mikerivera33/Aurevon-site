# ═══════════════════════════════════════════════════════
#  AUREVON ENVIRONMENT VARIABLES — .env.example
#  Copy this file to .env.local for local dev.
#  Set all variables in Vercel Dashboard → Settings → Env.
#  NEVER commit real values. .env* is in .gitignore.
# ═══════════════════════════════════════════════════════

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET
# After deploy → Stripe Dashboard → Webhooks → Add Endpoint
# URL: https://www.aurevonvc.com/api/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed

# ── PayPal ───────────────────────────────────────────────
PAYPAL_CLIENT_ID=AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxB
PAYPAL_SECRET=ExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxN
PAYPAL_BUSINESS_EMAIL=your-paypal@email.com
PAYPAL_MODE=live
# PAYPAL_SANDBOX=true   ← uncomment for sandbox testing

# ── Crossmint ─────────────────────────────────────────────
CROSSMINT_API_KEY=sk_production_xxxxxxxxxxxxxxxxxxxx
CROSSMINT_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_COLLECTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_CHAIN=base

# Template IDs per NFT tier (legacy single-collection)
CROSSMINT_TEMPLATE_INSIDER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_TEMPLATE_EMBER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_TEMPLATE_OBSIDIAN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_TEMPLATE_GENESIS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_TEMPLATE_CHROME=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Per-entitlement collection IDs (new entitlement system)
CROSSMINT_COLLECTION_MONTHLY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_COLLECTION_LIFETIME=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_COLLECTION_PRODUCT_A=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_COLLECTION_PRODUCT_B=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CROSSMINT_COLLECTION_PRODUCT_C=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Webhook secret (set after creating webhook in Crossmint Console)
CROSSMINT_WEBHOOK_SECRET=whsec_YOUR_CROSSMINT_WEBHOOK_SECRET
# URL: https://www.aurevonvc.com/api/webhooks/crossmint
# Events: action.succeeded, action.failed

# ── Resend ───────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@aurevongroup.com
RESEND_FROM_NAME=Aurevon

# ── Airtable (Aurevon Operations base) ───────────────────
AIRTABLE_PAT=patxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appI9X8vcRcK1QZ1l

# Override default table IDs if your Airtable uses different tables
# AIRTABLE_TABLE_MEMBERS=tblYPn7hxnrgH723B
# AIRTABLE_TABLE_PAYMENTS=tbl6KlhM9fIH19W5i
# AIRTABLE_TABLE_NFT_MINTS=tbliXEGJdoEIAJU06
# AIRTABLE_TABLE_CUSTOMER_AUTH=tblbCS7TL65FcOiWn
# AIRTABLE_TABLE_LEADS=tblDuezyOsxy7sNES

# ── Discord ───────────────────────────────────────────────
DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_GUILD_ID=000000000000000000
DISCORD_INVITE_URL=https://discord.gg/your-invite-code

# Discord Role IDs — one per entitlement type
# Right-click role in Server Settings → Copy Role ID
DISCORD_ROLE_MONTHLY=000000000000000000
DISCORD_ROLE_LIFETIME=000000000000000000
DISCORD_ROLE_PRODUCT_A=000000000000000000
DISCORD_ROLE_PRODUCT_B=000000000000000000
DISCORD_ROLE_PRODUCT_C=000000000000000000

# ── App config ────────────────────────────────────────────
DOMAIN=https://www.aurevonvc.com

# Security tokens — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STATE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SYNC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECONCILE_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Entitlement config
ENTITLEMENT_GRACE_PERIOD_DAYS=7

# ── Collab.Land ───────────────────────────────────────────
# Not a backend env var — configured via Collab.Land dashboard
# Record your community ID here for reference
COLLABLAND_COMMUNITY_ID=your-community-id

# ── Engage.io / Engage AI ─────────────────────────────────
ENGAGE_IO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
ENGAGE_IO_WORKSPACE_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# ── CI / Vercel ───────────────────────────────────────────
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
# Set in GitHub Secrets (repo → Settings → Secrets → Actions), NOT here
VERCEL_FORCE_NO_BUILD_CACHE=1
