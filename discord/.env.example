# ── Aurevon Discord Setup Bot — .env.example ─────────────────────────────────
# Copy this file to .env and fill in your values before running npm run setup.
# NEVER commit real values. .env is in .gitignore.

# Your Discord bot token (Bot tab in Developer Portal → Reset Token)
DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Right-click your server icon in Discord → Copy Server ID (Developer Mode must be ON)
DISCORD_GUILD_ID=000000000000000000

# Your Aurevon site URL (used in embed buttons)
# Leave blank to use the default: https://www.aurevonvc.com
SITE_URL=https://www.aurevonvc.com
