# ── Aurevon Discord Bot — .env.example ───────────────────────────────────────
# Copy to .env and fill in every value before running.
# NEVER commit real values. discord/.env is in .gitignore.

# ── Required: Bot credentials ─────────────────────────────────────────────────
# Developer Portal → your app → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Aurevon Ventures server ID (confirmed from discord.gg/aJBtPfAk invite)
DISCORD_GUILD_ID=1499526813490221207

# Developer Portal → General Information → Application ID
# (Aurevon Labs Community — same app wired to Vercel for website OAuth)
DISCORD_CLIENT_ID=1506515165003255889

# Developer Portal → OAuth2 → Client Secret
DISCORD_CLIENT_SECRET=

# ── Required: Role IDs ────────────────────────────────────────────────────────
# These are output at the end of: npm run setup
# Paste the values printed there directly below.

DISCORD_ROLE_MONTHLY=       # 001 Genesis   — monthly_membership
DISCORD_ROLE_LIFETIME=      # 004 Chrome    — lifetime_membership
DISCORD_ROLE_PRODUCT_A=     # Aurevon Insider   — product_a_reward
DISCORD_ROLE_PRODUCT_B=     # Aurevon Ember     — product_b_reward
DISCORD_ROLE_PRODUCT_C=     # Aurevon Obsidian Executive — product_c_reward
DISCORD_ROLE_VERIFIED=      # Verified Member

# ── Required: Airtable (shared with Vercel) ───────────────────────────────────
AIRTABLE_PAT=
AIRTABLE_BASE_ID=appI9X8vcRcK1QZ1l

# Table ID overrides (optional — defaults are already correct)
# AIRTABLE_TABLE_MEMBERS=tblYPn7hxnrgH723B
# AIRTABLE_TABLE_NFT_MINTS=tbliXEGJdoEIAJU06

# ── Optional ──────────────────────────────────────────────────────────────────
SITE_URL=https://www.aurevonvc.com
